# Crypto market data
BINANCE_API_URL=https://api.binance.com
BINANCE_WS_URL=wss://stream.binance.com:9443/stream
EXCHANGE_TYPE=binance
EXCHANGE_ENABLE_RATE_LIMIT=true
EXCHANGE_RATE_LIMIT=1200
EXCHANGE_TIMEOUT_MS=30000
BINANCE_API_KEY=
BINANCE_API_SECRET=
COINBASE_API_KEY=
COINBASE_API_SECRET=
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# Server
BACKEND_PORT=8000
FRONTEND_PORT=3000
CORS_ORIGINS=["http://localhost:3000"]
BACKTEST_API_KEY=
BACKTEST_RATE_LIMIT_PER_MINUTE=10

# Simulation
BAR_SIZE=5m
DEFAULT_FEE_RATE=0.001
DEFAULT_FEE_EXPONENT=2.0
BACKTEST_EXECUTION_MODE=event_driven
BACKTEST_FILL_MODEL=M2
BACKTEST_NETWORK_LATENCY_MS=50
BACKTEST_EXCHANGE_LATENCY_MS=20

# ML
MODEL_DIR=models
DATA_DIR=data
INDICATOR_LIBRARY=auto
FEATURE_SCALER_TYPE=standard
FEATURE_IMPORTANCE_METHOD=tree

# Paper strategy + risk
PAPER_STRATEGY_INTERFACE=mixed
MAX_POSITION_PER_MARKET=1000
MAX_TOTAL_EXPOSURE=5000
MAX_DAILY_LOSS=500

# Discord notifications
DISCORD_WEBHOOK_URL=
DISCORD_RATE_LIMIT_PER_MINUTE=10
DISCORD_ENABLED_CATEGORIES=ERROR,WARNING,INFO,TRADE,RISK,SYSTEM

# OpenClaw (Discord + Kimi K2 autonomous assistant)
OPENCLAW_ENVIRONMENT=development
OPENCLAW_DATA_DIR=data/openclaw
OPENCLAW_LOG_LEVEL=INFO
OPENCLAW_LOG_FILE=data/openclaw/openclaw.log
OPENCLAW_MARKETPY_BASE_URL=http://localhost:8000
OPENCLAW_SKILLS_DIR=backend/app/openclaw/skills

OPENCLAW_DISCORD_BOT_TOKEN=
OPENCLAW_DISCORD_COMMAND_PREFIX=!
OPENCLAW_DISCORD_AUTHORIZED_USERS=
OPENCLAW_DISCORD_ADMIN_CHANNEL=
OPENCLAW_DISCORD_COMMAND_CHANNELS=

OPENCLAW_KIMI_K2_API_KEY=
OPENCLAW_KIMI_K2_BASE_URL=https://api.moonshot.cn/v1
OPENCLAW_KIMI_K2_MODEL=moonshot-v1-8k
OPENCLAW_KIMI_K2_MAX_TOKENS=4096
OPENCLAW_KIMI_K2_TIMEOUT=30
OPENCLAW_KIMI_K2_RATE_LIMIT=60
OPENCLAW_KIMI_K2_MAX_CONCURRENT=5

OPENCLAW_MARKET_MONITOR_INTERVAL=60
OPENCLAW_RISK_MONITOR_INTERVAL=60
OPENCLAW_CONTEXT_BACKUP_INTERVAL=300

OPENCLAW_RISK_MAX_POSITION_SIZE_PCT=20
OPENCLAW_RISK_MAX_DAILY_LOSS_PCT=5
OPENCLAW_RISK_MAX_OPEN_POSITIONS=10
OPENCLAW_RISK_MIN_TRADE_INTERVAL=60
OPENCLAW_RISK_MAX_ORDER_SIZE=100000

OPENCLAW_PERF_MAX_CONCURRENT_USERS=10
OPENCLAW_PERF_COMMAND_TIMEOUT=30
OPENCLAW_PERF_MAX_QUEUE_SIZE=100
OPENCLAW_PERF_SIMPLE_SLA=2
OPENCLAW_PERF_COMPLEX_SLA=10

OPENCLAW_CONTEXT_ENCRYPTION_KEY=
OPENCLAW_SECURITY_PER_USER_RATE_LIMIT=30
OPENCLAW_SECURITY_ENABLE_REQUEST_SIGNING=false
OPENCLAW_SECURITY_SIGNING_SECRET=
